<% layout("/layouts/boilerplate") %>

    <% if(bookings.length> 0){ %>

        <div class="row g-4">

            <% bookings.forEach((booking)=> { %>
                <p>
                    Listing Exists:
                    <%= booking.listing ? "YES" : "NO" %>
                </p>

                <% if(booking.listing){ %>

                    <div class="col-md-4 mb-4">

                        <div class="card listing-card trip-card h-100 shadow-sm">

                            <img src="<%= booking.listing.images?.[0]?.url || 'https://via.placeholder.com/400x300' %>"
                                class="card-img-top trip-img">

                            <div class="card-body d-flex flex-column">

                                <h5>
                                    <%= booking.listing.title %>
                                </h5>

                                <p>
                                    Check In:
                                    <%= booking.checkIn.toDateString() %>
                                </p>

                                <p>
                                    Check Out:
                                    <%= booking.checkOut.toDateString() %>
                                </p>

                                <p>
                                    Guests:
                                    <%= booking.guests %>
                                </p>

                                <p>

                                    Status:

                                    <% if(booking.status==="Upcoming" ){ %>

                                        <span class="badge bg-warning text-dark">
                                            Upcoming
                                        </span>

                                        <% } else if(booking.status==="Ongoing" ){ %>

                                            <span class="badge bg-success">
                                                Ongoing
                                            </span>

                                            <% } else { %>

                                                <span class="badge bg-secondary">
                                                    Completed
                                                </span>

                                                <% } %>

                                </p>

                                <form class="mt-auto"
                                    action="/listings/<%= booking.listing._id %>/bookings/<%= booking._id %>?_method=DELETE"
                                    method="POST">

                                    <button class="btn btn-outline-danger cancel-btn w-100">

                                        Cancel Booking

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                    <% } %>

                        <% }) %>

        </div>

        <% } else { %>

            <div class="text-center py-5">

                <h1>✈️</h1>

                <h3>No trips booked yet</h3>

                <p class="text-muted">
                    Book your first adventure.
                </p>

                <a href="/listings" class="btn btn-danger">

                    Find a Stay

                </a>

            </div>

            <% } %>