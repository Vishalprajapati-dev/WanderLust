        </script> -->

    </div>
    <!-- Gallery Modal -->

    <div class="modal fade" id="galleryModal" tabindex="-1">

        <div class="modal-dialog modal-fullscreen">

            <div class="modal-content bg-dark">

                <div class="modal-header border-0">

                    <h5 class="modal-title text-white">
                        <%= listing.title %>
                    </h5>

                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <div class="airbnb-gallery">

                        <div class="gallery-preview">

                            <img id="previewImage"
                                src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : '' %>"
                                alt="">

                        </div>

                        <div class="gallery-thumbnails">

                            <% if(listing.images && listing.images.length> 0){ %>

                                <% listing.images.forEach((img)=>{ %>

                                    <img src="<%= img.url %>" onclick="changePreview(this.src)">

                                    <% }) %>

                                        <% } %>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
    </div>
    <script>

        function changePreview(src) {

            document.getElementById("previewImage").src = src;

        }

    </script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <input type="hidden" id="bookedDatesData" value='<%- JSON.stringify(bookedDates) %>'>
    <script src="/js/bookingCalendar.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        async function shareListing() {

            const shareData = {

                title: "<%= listing.title %>",

                text: "Check out this amazing stay on WanderLust!",

                url: window.location.href
            };

            if (navigator.share) {

                try {

                    await navigator.share(shareData);

                } catch (err) {

                    console.log(err);

                }

            } else {

                navigator.clipboard.writeText(
                    window.location.href
                );

                alert(
                    "🔗 Listing link copied to clipboard!"
                );
            }
        }

    </script>

    <script>

        const tooltipTriggerList =
            document.querySelectorAll(
                '[data-bs-toggle="tooltip"]'
            );

        [...tooltipTriggerList].map(
            tooltipTriggerEl =>
                new bootstrap.Tooltip(
                    tooltipTriggerEl
                )
        );

    </script>

    <script>

        document
            .getElementById("rzp-button")
            .addEventListener("click", async function () {

                const total =
                    Number(
                        document
                            .getElementById("totalPrice")
                            .textContent
                            .replace(/,/g, "")
                    );

                if (total <= 0) {
                    alert("Please select valid dates");
                    return;
                }

                const response =
                    await fetch("/payment/create-order", {

                        method: "POST",

                        headers: {
                            "Content-Type": "application/json",
                        },

                        body: JSON.stringify({
                            amount: total,
                        }),
                    });

                const order = await response.json();
                console.log("Razorpay Key:", "<%= razorpayKey %>");
                const options = {

                    key: "<%= razorpayKey %>",

                    amount: order.amount,

                    currency: order.currency,

                    name: "WanderLust",

                    description: "Property Reservation",

                    order_id: order.id,

                    handler: function () {

                        document
                            .getElementById("bookingForm")
                            .submit();
                    },

                    theme: {
                        color: "#ff385c"
                    }
                };
                console.log("Razorpay options:", options);
                const rzp =
                    new Razorpay(options);
                rzp.on("payment.failed", function () {

                    alert("Demo Payment Successful");

                    document.getElementById("bookingForm").submit();

                });
                rzp.open();
            });

    </script>